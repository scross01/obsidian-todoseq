# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# exclude local tools
.env

# exclude coverage report
coverage/

# exclude roo files
.roo/
.rooignore
.roomodes
plans/

# exclude kilocode files
.kilocode/
.kilocodemodes

# ignore feature planning docs
FEAT*.md

Makefile

.obsidian/plugins/
.obsidian/workspace.json

# VitePress build output
docs/.vitepress/dist
docs/.vitepress/cache

# Claude Code
CLAUDE.md
.claude/
.obsidian/themes/
examples/Test Performance/*

# TypeScript build info
tsconfig.tsbuildinfo

# Integration test fixtures (ephemeral, regenerated by the harness).
# Ignore the directory CONTENTS (/*) not the directory itself, so specific
# committed fixtures can be re-included with negations below.
tests/integration/fixtures/*
tests/integration/test-results/

# Keep the committed baseline plugin-settings fixture (deterministic test start)
!tests/integration/fixtures/baseline-plugin-data.json

.poolside/
.agents/
skills-lock.json
test-results/.last-run.json
.mimocode/
