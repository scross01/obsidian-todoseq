{
  "name": "todoseq",
  "version": "0.14.0-dev",
  "description": "TODOseq lightweight, keyword-based task tracker for Obsidian",
  "license": "MIT",
  "author": "Stephen Cross",
  "main": "main.js",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.25.8",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "obsidian": ">=0.12.12",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:debug": "node esbuild.watch.mjs",
    "copy": "./scripts/copy-to-obsidian.sh",
    "build": "tsc -p tsconfig.json --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "build:debug": "node esbuild.build.mjs && npm run copy",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "node --no-warnings node_modules/.bin/jest --silent",
    "format": "prettier --write .",
    "lint": "eslint .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "generate-content": "ts-node scripts/content-generator.ts"
  },
  "dependencies": {
    "obsidian-daily-notes-interface": "^0.9.4"
  },
  "overrides": {
    "esbuild": "^0.25.8"
  }
}
